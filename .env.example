# Образец настроек Блока 0. Скопируй в .env и заполни под себя.
# Сам .env в git НЕ попадает (секреты). Здесь — только пример без реальных значений.

# Лимит обращений к Fitbase (турникет, запросов в секунду). По умолчанию 20.
FITBASE_MAX_RPS=20

# Подключение к Redis. Локально обычно так:
REDIS_URL=redis://localhost:6379/0

# Общий секрет вебхука Wazzup (заголовок Authorization: Bearer <этот секрет>).
# Задаём в кабинете Wazzup и сюда же; чужой/пустой → дверь отбивает (401).
WAZZUP_WEBHOOK_SECRET=dev-secret-change-me

# id автора-продавца в Wazzup (узнаём на триале). Пусто = продавца по authorId не метим.
SELLER_AUTHOR_ID=
