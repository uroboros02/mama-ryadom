# Секреты — никогда не в git
.env
.env.*
!.env.example
*.key
*.pem

# Python (генерируется само, в git не нужно)
__pycache__/
*.pyc
.venv/
venv/

# Персональные данные клиентов — НЕ коммитим (152-ФЗ, есть GitHub-remote)
chats wazzup.csv
*.csv
data/
finmodel/данные/
# ВНИМАНИЕ: data/ игнорируется ЦЕЛИКОМ. Если когда-нибудь нужно положить в data/
# НЕ-ПД файл под git — добавь исключение строкой ниже, напр.:  !data/имя-файла.md
# Проверить, видит ли git файл:  git check-ignore -v <путь>

# Мусор и локальные индексы
.DS_Store
.codegraph/

# Аудиозаписи — не коммитим (размер + чувствительность); транскрипты (.txt) коммитим
*.mp3
*.m4a

# Локальное окружение транскрипции (venv + кэш модели ~3.7G) — удаляемое целиком
whisper/
